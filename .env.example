# Edge5 — Vercel Environment Variables
# Copy these keys into Vercel Dashboard → Project → Settings → Environment Variables
# Never commit actual values. This file is a template only.

FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=edge5-prod.firebaseapp.com
FIREBASE_PROJECT_ID=edge5-prod
FIREBASE_STORAGE_BUCKET=edge5-prod.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# URL of the deployed Firebase Function
COUNSELLOR_FUNCTION_URL=https://asia-south1-edge5-prod.cloudfunctions.net/counsellor

# Set this in Firebase Secret Manager (NOT Vercel):
# CLAUDE_API_KEY=sk-ant-...
